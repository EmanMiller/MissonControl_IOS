                                <constraints>
                                    <constraint firstItem="logo-text" firstAttribute="centerX" secondItem="logo-wrap" secondAttribute="centerX" id="logo-center-x"/>
                                    <constraint firstItem="logo-text" firstAttribute="centerY" secondItem="logo-wrap" secondAttribute="centerY" id="logo-center-y"/>
                                </constraints>
