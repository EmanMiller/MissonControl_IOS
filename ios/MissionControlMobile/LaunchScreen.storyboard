    <scenes>
        <scene sceneID="scene-launch">
            <objects>
                <viewController id="vc-launch" sceneMemberID="viewController">
                    <view key="view" contentMode="scaleToFill" id="view-root">
                        <rect key="frame" x="0.0" y="0.0" width="393" height="852"/>
                        <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                        <subviews>
                            <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="logo-wrap">
                                <rect key="frame" x="150" y="356" width="93" height="93"/>
                                <subviews>
                                    <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="MC" textAlignment="center" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" minimumFontSize="10" translatesAutoresizingMaskIntoConstraints="NO" id="logo-text">
                                        <rect key="frame" x="21" y="30.666666666666686" width="51.333333333333343" height="31.666666666666629"/>
                                        <fontDescription key="fontDescription" type="boldSystem" pointSize="26"/>
                                        <color key="textColor" red="0.18823529410000001" green="0.81960784309999995" blue="0.34509803919999998" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                        <nil key="highlightedColor"/>
